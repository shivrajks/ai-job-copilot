# =============================================================================
# AI Job Copilot — Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp backend/.env.example backend/.env
#
# Defaults shown below work for local development with docker compose.
# =============================================================================

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aicopilot
DB_USERNAME=aicopilot
DB_PASSWORD=aicopilot

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT ---
# Generate with: openssl rand -base64 32
# Minimum 256 bits for HS256. Do NOT use the example value in production.
JWT_SECRET=dev-jwt-secret-key-ai-copilot-2024-at-least-256-bits-long!!

# --- AI Provider ---
# Options: gemini, mock
AI_PROVIDER=mock

# --- Gemini AI ---
# Get a free API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- SMTP / Email ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true

# --- CORS ---
# Comma-separated origins allowed for cross-origin requests
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- App ---
# Public base URL of the frontend application
APP_BASE_URL=http://localhost:3000

# --- File Storage ---
RESUME_STORAGE_PATH=./uploads/resumes
