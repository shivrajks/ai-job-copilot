# =============================================================================
# AI Job Copilot — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp frontend/.env.example frontend/.env.local
#
# Only NEXT_PUBLIC_* variables are exposed to the browser.
# All other variables in .env.local are server-side only.
# =============================================================================

# --- API URL ---
# Backend API base URL (do NOT include /api suffix — backend adds the context path)
# For local dev with docker compose: http://localhost:8080
# For production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- App URL ---
# Public base URL of the frontend itself
# Used for SEO, OG tags, and absolute URLs in server components
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional: Analytics / Monitoring ---
# Google Analytics measurement ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking
# NEXT_PUBLIC_SENTRY_DSN=
